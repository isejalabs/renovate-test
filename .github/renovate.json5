{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    ":disableRateLimiting",
    "config:best-practices",
    "github>isejalabs/renovate-test//.github/renovate/labels.json5",
    "github>isejalabs/renovate-test//.github/renovate/organize-semantic-scope.json5",
    "github>isejalabs/renovate-test//.github/renovate/pin-versions.json5",
    "github>isejalabs/renovate-test//.github/renovate/version-scheme.json5",
  ],
  rebaseWhen: 'conflicted',
  separateMinorPatch: true,
  ignorePaths: [
    '_attic/**',
  ],
  semanticCommitScope: '{{parentDir}}',
  terragrunt: {
    versioning: 'regex:^((?<compatibility>.*)-v|v*)(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$',
  },
  additionalBranchPrefix: '{{packageFileDir}}/',
  prBodyColumns: [
    'Package',
    'Package file',
    'Update',
    'Change',
  ],
  kustomize: {
    managerFilePatterns: [
      '/(^|/)kustomization\\.ya?ml(\\.j2)?$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/(^|/)k8s/.+\\.yaml$/',
      '/(^|/)regex/.+\\.yaml$/',
      '/(^|/)vanilla/.+\\.yaml$/',
    ],
  },
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/\\.hcl$/',
        '/\\.tf$/',
        '/\\.tftpl$/',
        '/\\.yaml$/',
        '/\\.sh$/',
      ],
      matchStrings: [
        '(?<currentValue>[\\w+\\.\\-]*)[\'",;]*\\s*#\\s?renovate: (?<datasource>\\S+)=(?<depName>\\S+)\\s?(registry=(?<registryUrl>\\S+))?\\s?(versioning=(?<versioning>\\S+))?',
      ],
    },
  ],
  packageRules: [
    {
      matchPackageNames: [
        '/^lscr.io\\/linuxserver\\/unifi-network-application\\//',
      ],
      versioning: 'regex:^(?<compatibility>[a-z]*-|v)?(?<major>\\d+)\\.(?<minor>d+)\\.(?<patch>\\d+)?(?:[\\.-]?(?<build>.*))?$',
    },
    {
      matchUpdateTypes: [
        'digest',
        'pinDigest',
      ],
      automerge: true,
    },
    {
      matchDepTypes: [
        'devDependencies',
      ],
      automerge: true,
    },
  ],
  platformAutomerge: true,
}
