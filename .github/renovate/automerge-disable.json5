{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "disable automerge for specific packages",
      matchPackageNames: [
        "github.com/isejalabs/terraform-proxmox-talos",
        "kubernetes-sigs/gateway-api",
        "kubernetes/kubernetes",
        "sidero/talos",
      ],
      automerge: false,
      addLabels: ["updateStrategy:manual"],
    },
    {
      description: "disable automerge for specific file paths",
      matchFileNames: [".github/**", "terragrunt/**", "tofu/**"],
      automerge: false,
      addLabels: ["updateStrategy:manual"],
    },
  ],
}
