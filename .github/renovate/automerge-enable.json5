{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchUpdateTypes: [
        'digest',
        'pinDigest',
      ],
      "automerge": true,
      "addLabels": [
        "automerge:on"
      ],
    },
    {
      matchDepTypes: [
        'devDependencies',
      ],
      "automerge": true,
      "addLabels": [
        "automerge:on"
      ],
    },
  ],
  platformAutomerge: true,
}
